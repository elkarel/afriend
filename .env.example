# Ollama base URL — default is localhost when Ollama runs on the same machine
OLLAMA_HOST=http://localhost:11434

# DeepSeek model to use (must be pulled via: ollama pull <model>)
# Lightweight options: deepseek-r1:1.5b, deepseek-r1:7b
# Coding-focused:      deepseek-coder:6.7b
DEEPSEEK_MODEL=deepseek-r1:1.5b

# Directory where per-phone markdown chat logs are stored
CHATS_DIR=chats

# Flask settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
